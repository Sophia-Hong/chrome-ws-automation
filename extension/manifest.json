{
  "manifest_version": 3,
  "name": "Browser Automation Bridge",
  "version": "1.0.0",
  "description": "WebSocket bridge for browser automation — keke_appa style",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Browser Automation Bridge"
  },
  "icons": {}
}
